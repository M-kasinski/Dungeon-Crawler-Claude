# Storage backend: "file" (local JSON) or "redis" (Upstash / Vercel KV)
STORAGE_BACKEND=file

# Redis URL — required when STORAGE_BACKEND=redis
# Vercel KV injects this automatically when you link a KV database to your project.
# For local Redis: redis://localhost:6379
# For Upstash:     rediss://default:<password>@<host>.upstash.io:<port>
REDIS_URL=
